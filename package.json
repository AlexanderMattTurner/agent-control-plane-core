{
  "name": "agent-control-plane-core",
  "version": "0.1.0",
  "description": "Vendor-neutral control-plane contract for coding agents: a normalized ToolCallEvent/Verdict schema with per-agent adapters (Claude Code, Codex, Amp, Gemini CLI) and a conformance suite.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexanderMattTurner/agent-control-plane-core.git"
  },
  "bugs": {
    "url": "https://github.com/AlexanderMattTurner/agent-control-plane-core/issues"
  },
  "homepage": "https://github.com/AlexanderMattTurner/agent-control-plane-core#readme",
  "license": "MIT",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "main": "./src/index.mjs",
  "types": "./types/index.d.mts",
  "exports": {
    ".": {
      "types": "./types/index.d.mts",
      "import": "./src/index.mjs"
    },
    "./claude": {
      "types": "./types/adapters/claude.d.mts",
      "import": "./src/adapters/claude.mjs"
    },
    "./codex": {
      "types": "./types/adapters/codex.d.mts",
      "import": "./src/adapters/codex.mjs"
    },
    "./amp": {
      "types": "./types/adapters/amp.d.mts",
      "import": "./src/adapters/amp.mjs"
    },
    "./gemini": {
      "types": "./types/adapters/gemini.d.mts",
      "import": "./src/adapters/gemini.mjs"
    },
    "./conformance": {
      "types": "./types/conformance.d.mts",
      "import": "./src/conformance.mjs"
    },
    "./registry": {
      "types": "./types/registry.d.mts",
      "import": "./src/registry.mjs"
    }
  },
  "files": [
    "src",
    "types",
    "bin"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "agent",
    "control-plane",
    "hooks",
    "adapter",
    "guardrail"
  ],
  "scripts": {
    "prepare": "node scripts/prepare.mjs",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build",
    "test": "node --test test/*.test.mjs",
    "test:coverage": "c8 node --test test/*.test.mjs",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.json.example": [
      "prettier --write --parser json"
    ],
    "*.{js,jsx,ts,tsx,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{yaml,yml}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ],
    ".claude/skills/*/SKILL.md": [
      ".hooks/lint-skills.sh"
    ],
    "{*.sh,.hooks/*}": [
      "shfmt -i 2 -w"
    ],
    "*.py": [
      "ruff check --fix",
      "ruff format"
    ]
  },
  "dependencies": {
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "@types/semver": "^7.5.8",
    "c8": "^10.1.2",
    "eslint": "^9.13.0",
    "fast-check": "^3.22.0",
    "globals": "^15.11.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0"
  }
}
